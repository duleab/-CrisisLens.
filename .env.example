# Database Configuration
DATABASE_URL=sqlite:///./crisislens.db
# For PostgreSQL: postgresql://crisislens_user:password@localhost:5432/crisislens

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# API Keys (Get these from respective providers)
GOOGLE_API_KEY=your_google_api_key_here
NEWSAPI_KEY=your_newsapi_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Application Settings
DEBUG=true
LOG_LEVEL=INFO

# Docker specific (for production)
DB_PASSWORD=crisislens_secure_password
REDIS_PASSWORD=redis_secure_password

# Frontend URLs
FRONTEND_API_URL=http://localhost:8000/api/v1
FRONTEND_WS_URL=ws://localhost:8000/ws

# Monitoring (optional)
GRAFANA_PASSWORD=admin