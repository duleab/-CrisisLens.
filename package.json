{
  "name": "crisislens-production",
  "version": "2.0.0",
  "description": "Production-ready CrisisLens AI disaster intelligence platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && pip install -r requirements.txt",
    "start": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && pytest",
    "test:frontend": "cd frontend && npm run test",
    "deploy": "npm run build && docker-compose -f docker-compose.prod.yml up -d"
  },
  "keywords": [
    "crisis-management",
    "disaster-intelligence", 
    "ai-platform",
    "emergency-response",
    "gemma-ai",
    "multi-agent-system"
  ],
  "author": "CrisisLens Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.9.0"
  }
}